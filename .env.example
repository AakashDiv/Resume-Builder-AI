# Backend
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai_resume_builder
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=https://your-vercel-app.vercel.app
CLIENT_BASE_URL=https://your-vercel-app.vercel.app
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
OPENAI_EMBEDDING_MAX_CHARS=2000
OPENAI_EMBEDDING_PROVIDER=openai
RAPIDAPI_KEY=your-rapidapi-key
JSEARCH_HOST=jsearch.p.rapidapi.com
JSEARCH_NUM_PAGES=1
REDIS_URL=redis://127.0.0.1:6379
QUEUE_ENABLED=true
AUTO_APPLY_DRY_RUN=true
AUTO_APPLY_HEADLESS=true
AUTO_APPLY_DELAY_MS=30000
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata
JOB_MATCHER_CRON=0 9 * * *
DAILY_DIGEST_CRON=0 9 * * *
SCHEDULER_RUN_ON_START=false
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ResumeBuilder AI <no-reply@localhost>
PYTHON_BIN=python
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# Frontend
VITE_API_BASE_URL=https://your-render-backend.onrender.com/api
