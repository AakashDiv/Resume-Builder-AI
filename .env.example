# Copy this file to `.env` for local development.
# For live deployment, set the production values in your hosting provider instead of committing secrets.

# ---------------------------------------------------------------------------
# Backend - shared
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai_resume_builder
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
CLIENT_BASE_URL=http://localhost:5173
PYTHON_BIN=python

# ---------------------------------------------------------------------------
# Local-safe defaults
# ---------------------------------------------------------------------------
OPENAI_EMBEDDING_PROVIDER=fallback
AUTO_APPLY_DRY_RUN=true
AUTO_APPLY_HEADLESS=true
EMAIL_ENABLED=false
SCHEDULER_RUN_ON_START=false
REDIS_URL=redis://127.0.0.1:6379
QUEUE_ENABLED=true
ALLOW_TEST_PRO_UPGRADE=true

# ---------------------------------------------------------------------------
# OpenAI
# Local: fallback is fine.
# Live: set OPENAI_EMBEDDING_PROVIDER=openai and provide a funded API key.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
OPENAI_EMBEDDING_MAX_CHARS=2000

# ---------------------------------------------------------------------------
# JSearch / RapidAPI
# ---------------------------------------------------------------------------
RAPIDAPI_KEY=
JSEARCH_HOST=jsearch.p.rapidapi.com
JSEARCH_NUM_PAGES=1

# ---------------------------------------------------------------------------
# Auto apply
# Keep dry-run true until real LinkedIn/Naukri tests are manually verified.
# ---------------------------------------------------------------------------
AUTO_APPLY_DELAY_MS=30000
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# ---------------------------------------------------------------------------
# Scheduler
# Runs daily at 9 AM Asia/Kolkata by default.
# Frontend Pro users can stop/start automatic work from Dashboard.
# ---------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata
JOB_MATCHER_CRON=0 9 * * *
DAILY_DIGEST_CRON=0 9 * * *

# ---------------------------------------------------------------------------
# Email
# Local EMAIL_ENABLED=false logs/skips email.
# Live EMAIL_ENABLED=true requires SMTP settings.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ResumeBuilder AI <no-reply@localhost>

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ---------------------------------------------------------------------------
# Frontend
# frontend/.env should usually contain this local value:
# VITE_API_BASE_URL=http://localhost:5000/api
#
# Live frontend should use your deployed backend:
# VITE_API_BASE_URL=https://your-render-backend.onrender.com/api
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api

# ---------------------------------------------------------------------------
# Live deployment overrides checklist
# ---------------------------------------------------------------------------
# NODE_ENV=production
# CLIENT_ORIGIN=https://your-frontend-domain
# CLIENT_BASE_URL=https://your-frontend-domain
# MONGO_URI=<production mongodb uri>
# REDIS_URL=<production redis or rediss url>
# OPENAI_EMBEDDING_PROVIDER=openai
# AUTO_APPLY_DRY_RUN=false only after manual live dry-run testing
# EMAIL_ENABLED=true after SMTP is configured
# ALLOW_TEST_PRO_UPGRADE=false
